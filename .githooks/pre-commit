#!/bin/bash
# Pre-commit hook: block commits containing hardcoded secrets
# Install: git config core.hooksPath .githooks

RED='\033[0;31m'
NC='\033[0m' # No Color

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -v 'pre-commit' | grep -v '\.githooks/')

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

ERRORS=0

# Patterns to check (regex | description)
PATTERNS=(
  "sshpass|sshpass usage detected"
  "Aubinaud|Known password detected"
  "dkoocok3j|Cloudinary cloud name detected"
  "REDACTED_KEY|Cloudinary API key detected"
  "REDACTED_SECRET|Cloudinary API secret detected"
  "95\.111\.254\.27|Hardcoded VPS IP detected"
  "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9\.[A-Za-z0-9_-]{20,}|Hardcoded JWT token detected"
  "amas-wolf-secret-change-in-production|Hardcoded JWT fallback detected"
  "amas-space-secret-2026|Hardcoded JWT fallback detected"
  "emailmarketing-notifuse\.s6hx3x\.easypanel\.host|Hardcoded Notifuse URL detected"
)

for entry in "${PATTERNS[@]}"; do
  PATTERN="${entry%%|*}"
  DESC="${entry##*|}"

  # Search only staged content (not filenames, not .env files)
  MATCHES=$(echo "$STAGED_FILES" | grep -v '\.env$' | xargs git diff --cached -- 2>/dev/null | grep -E "^\+" | grep -v "^+++" | grep -iE "$PATTERN" || true)

  if [ -n "$MATCHES" ]; then
    echo -e "${RED}BLOCKED:${NC} $DESC"
    echo "$MATCHES" | head -3
    echo ""
    ERRORS=$((ERRORS + 1))
  fi
done

# Check for generic password patterns in code files (not .env, not .example)
CODE_FILES=$(echo "$STAGED_FILES" | grep -E '\.(js|ts|json|md|yml|yaml|sh)$' | grep -v '\.env' | grep -v 'pre-commit' || true)
if [ -n "$CODE_FILES" ]; then
  PASS_MATCHES=$(echo "$CODE_FILES" | xargs git diff --cached -- 2>/dev/null | grep -E "^\+" | grep -v "^+++" | grep -iE "password\s*[:=]\s*['\"][a-zA-Z0-9]{10,}['\"]" || true)
  if [ -n "$PASS_MATCHES" ]; then
    echo -e "${RED}BLOCKED:${NC} Hardcoded password pattern detected"
    echo "$PASS_MATCHES" | head -3
    echo ""
    ERRORS=$((ERRORS + 1))
  fi
fi

if [ $ERRORS -gt 0 ]; then
  echo -e "${RED}Commit blocked: $ERRORS secret pattern(s) found.${NC}"
  echo "Remove the secrets and try again, or use --no-verify to bypass (NOT recommended)."
  exit 1
fi

exit 0
